---
interface Props {
  src: string;
  alt: string;
  label?: string;
  caption?: string;
  fullWidth?: boolean;
}

const { src, alt, label, caption, fullWidth = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<figure class:list={["rounded-sm overflow-hidden border border-war-border", { "max-w-3xl mx-auto": !fullWidth }]}>
  {label && (
    <div class="bg-war-surface2 border-b border-war-border px-3 py-1.5 flex items-center gap-2">
      <span class="font-mono text-xxs text-war-amber uppercase tracking-widest">{label}</span>
    </div>
  )}
  <div class="bg-war-bg p-2">
    <img
      src={`${base}/${src}`}
      alt={alt}
      loading="lazy"
      decoding="async"
      class="w-full h-auto rounded-sm"
    />
  </div>
  {caption && (
    <figcaption class="bg-war-surface2 border-t border-war-border px-3 py-2 text-xs text-war-text-dim">
      {caption}
    </figcaption>
  )}
</figure>
