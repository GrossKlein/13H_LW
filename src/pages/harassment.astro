---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvidenceExhibit from '../components/EvidenceExhibit.astro';
import SlideProgress from '../components/SlideProgress';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Harassment Evidence" activeNav="harassment">
  <SlideProgress client:load />

  <div class="p-6 max-w-5xl mx-auto">

    <!-- Confidential Banner -->
    <div class="font-mono text-xxs text-war-red/60 uppercase tracking-[0.3em] text-center py-2 mb-6 border-b border-war-red/10">
      Privileged &amp; Confidential &mdash; Attorney Work Product
    </div>

    <!-- Section Jump Nav (populated by SlideProgress) -->
    <nav id="section-nav" class="sticky top-1 z-10 bg-war-bg/90 backdrop-blur border border-war-border rounded-sm py-2 px-4 mb-8 flex gap-4 overflow-x-auto">
    </nav>

    <!-- ===================== SLIDE 1: Title / Hero ===================== -->
    <section id="s1" data-slide="1" class="py-10 border-b border-war-border/30">
      <div class="text-center mb-8">
        <h1 class="font-display text-3xl text-war-text tracking-tight">13 Harrison Street</h1>
        <p class="font-mono text-sm text-war-text-muted mt-2">Tribeca, New York, NY 10013</p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <EvidenceExhibit
          src="harassment/slide-01-elevation-street.webp"
          alt="Existing Harrison Street Elevation — architectural drawing showing the building in context of the streetscape"
          label="Exhibit — Street Elevation"
        />
        <EvidenceExhibit
          src="harassment/slide-01-elevation-front.webp"
          alt="Existing Front Elevation — detailed architectural drawing of 13 Harrison Street facade with dimensions"
          label="Exhibit — Front Elevation"
        />
      </div>
    </section>

    <!-- ===================== SLIDE 2: Compass Floor Plan — Lower ===================== -->
    <section id="s2" data-slide="2" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">02</span>
        <h3 class="section-title">Compass Floor Plan — Lower Level</h3>
      </div>
      <p class="text-sm text-war-text-dim mb-4">As advertised on Real Estate Brokerage site</p>
      <EvidenceExhibit
        src="harassment/slide-02-floorplan-lower.webp"
        alt="Compass floor plan showing cellar level labeled with bedrooms, home office, and bathrooms — 13 Harrison Street Apt 1"
        label="Compass Listing Floor Plan — Lower Level"
        caption="Floor plan shows cellar rooms marketed as bedrooms with ensuite bathrooms, contradicting the Certificate of Occupancy designation."
      />
    </section>

    <!-- ===================== SLIDE 3: Compass Floor Plan — Upper ===================== -->
    <section id="s3" data-slide="3" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">03</span>
        <h3 class="section-title">Compass Floor Plan — Upper Level</h3>
      </div>
      <p class="text-sm text-war-text-dim mb-4">As advertised on Real Estate Brokerage site</p>
      <EvidenceExhibit
        src="harassment/slide-03-floorplan-upper.webp"
        alt="Compass floor plan showing upper level with Great Room, Kitchen, Home Office, Master Bedroom — 13 Harrison Street Apt 1, 3 Bed 4 Bath"
        label="Compass Listing Floor Plan — Upper Level"
      />
    </section>

    <!-- ===================== SLIDE 4: Timeline ===================== -->
    <section id="s4" data-slide="4" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-xxs text-war-text-muted">04</span>
        <h3 class="section-title">13 Harrison Timeline</h3>
        <span class="font-mono text-xxs text-war-text-muted ml-auto">Complete Forensic Chronology &amp; Evidence Map</span>
      </div>

      <!-- Metrics Row -->
      <div class="grid grid-cols-5 gap-3 mb-8">
        <div class="card text-center">
          <div class="metric-value text-war-red">8</div>
          <div class="metric-label">Counts</div>
        </div>
        <div class="card text-center">
          <div class="metric-value text-war-red">5</div>
          <div class="metric-label">Felonies</div>
        </div>
        <div class="card text-center">
          <div class="metric-value text-war-amber">$6–8M</div>
          <div class="metric-label">Demand</div>
        </div>
        <div class="card text-center">
          <div class="metric-value text-war-amber">79%</div>
          <div class="metric-label">Premium</div>
        </div>
        <div class="card text-center">
          <div class="metric-value text-war-text">19yr</div>
          <div class="metric-label">Exposure</div>
        </div>
      </div>

      <!-- Phase Timeline -->
      <div class="space-y-6 border-l-2 border-war-amber/30 ml-4 pl-6 mb-8">
        <!-- Phase I -->
        <div class="relative">
          <div class="absolute -left-[1.85rem] top-0.5 w-3 h-3 rounded-full bg-war-amber"></div>
          <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-1">I — The Illegal Foundation</div>
          <div class="font-mono text-xxs text-war-text-muted mb-2">1995–2018</div>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="text-war-text font-medium">1995</span> — C of O Issued: Cellar designated for storage/meters only. Never amended.</p>
            <p><span class="text-war-text font-medium">1995</span> — Condo Decl: Unit 1 = 25% interest, 2 baths. Roof = Unit 2 exclusive.</p>
            <p><span class="text-war-text font-medium">2017</span> — Broker Warning: BHS agent tells Bleich "not legal bedrooms." Bleich "annoyed."</p>
            <p><span class="text-war-text font-medium">Mar 2, 2018</span> — "Trigger Email": Bleich writes "bedrooms" knowing illegality.</p>
            <p><span class="text-war-text font-medium">~2007</span> — Illegal Conversion: Bleich builds 3 bedrooms + 2 baths in cellar (no egress).</p>
          </div>
        </div>

        <!-- Phase II -->
        <div class="relative">
          <div class="absolute -left-[1.85rem] top-0.5 w-3 h-3 rounded-full bg-war-amber"></div>
          <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-1">II — Marketing Fraud &amp; Knowledge</div>
          <div class="font-mono text-xxs text-war-text-muted mb-2">2017–2019</div>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="text-war-text font-medium">2018–19</span> — Listing Fraud: Compass forced to correct 4BR to 1BR. StreetEasy relabels cellar "1st Floor."</p>
          </div>
        </div>

        <!-- Phase III -->
        <div class="relative">
          <div class="absolute -left-[1.85rem] top-0.5 w-3 h-3 rounded-full bg-war-amber"></div>
          <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-1">III — Obstruction &amp; Governance</div>
          <div class="font-mono text-xxs text-war-text-muted mb-2">2020–2023</div>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="text-war-text font-medium">Pre-2024</span> — Access Denied: DOB inspectors blocked 3 times.</p>
            <p><span class="text-war-text font-medium">Sept 15, 2022</span> — Admission: Counsel admits cellar used for sleeping in court.</p>
            <p><span class="text-war-text font-medium">Oct 2022</span> — Leaks Begin: Water damage starts in Unit 2 kitchen/living room.</p>
            <p><span class="text-war-text font-medium">Dec 2023</span> — Temp Roof: Emergency install ($55k).</p>
          </div>
        </div>

        <!-- Phase IV -->
        <div class="relative">
          <div class="absolute -left-[1.85rem] top-0.5 w-3 h-3 rounded-full bg-war-red"></div>
          <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-1">IV — The Perjury–Injunction Nexus</div>
          <div class="font-mono text-xxs text-war-text-muted mb-2">Jun '24–Jan '25</div>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="text-war-text font-medium">Jun 21, 2024</span> — DOB Complaint: New illegal conversion filing (#1712420).</p>
            <p><span class="text-war-text font-medium">Jun 2024</span> — Concealment: Sheetrock barriers erected over cellar doors before DOB visit (Video).</p>
            <p><span class="text-war-text font-medium">Dec 12, 2025</span> — Perjury: Swears HVAC removal = "irreparable harm" (ACs broken).</p>
            <p><span class="text-war-text font-medium">Jan 17, 2025</span> — Injunction: Granted based on perjury. Halts roof work.</p>
          </div>
        </div>

        <!-- Phase V -->
        <div class="relative">
          <div class="absolute -left-[1.85rem] top-0.5 w-3 h-3 rounded-full bg-war-red"></div>
          <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-1">V — The Extortion</div>
          <div class="font-mono text-xxs text-war-text-muted mb-2">May–Sept 2025</div>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="text-war-text font-medium">May 24, 2025</span> — The Demand: Emails demand $6–8M. Own spreadsheet shows $4.4M value.</p>
            <p><span class="text-war-text font-medium">Aug 27, 2025</span> — Duress: Victim emails: "House leaking… let's take all demands off table."</p>
            <p><span class="text-war-text font-medium">Sept 26, 2025</span> — The Ransom: Term Sheet §5(a): Pay or injunction continues.</p>
          </div>
        </div>

        <!-- Phase VI -->
        <div class="relative">
          <div class="absolute -left-[1.85rem] top-0.5 w-3 h-3 rounded-full bg-war-amber"></div>
          <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-1">VI — The Unraveling</div>
          <div class="font-mono text-xxs text-war-text-muted mb-2">Oct–Dec 2025</div>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="text-war-text font-medium">Oct 23, 2025</span> — Gutted: Unit 2 kitchen demolished due to mold/leaks.</p>
            <p><span class="text-war-text font-medium">Nov 6, 2025</span> — HVAC Exposed: Technicians confirm NEITHER AC unit works. Perjury exposed.</p>
            <p><span class="text-war-text font-medium">Dec 12, 2025</span> — DOB Complaint: New illegal conversion filing (#1712420).</p>
          </div>
        </div>

        <!-- Phase VII -->
        <div class="relative">
          <div class="absolute -left-[1.85rem] top-0.5 w-3 h-3 rounded-full bg-war-red"></div>
          <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-1">VII — Continuing Obstruction</div>
          <div class="font-mono text-xxs text-war-text-muted mb-2">Jan 2026–Present</div>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="text-war-text font-medium">Jan 15, 2026</span> — Access Denied: DOB inspector blocked again.</p>
            <p><span class="text-war-text font-medium">Jan 28, 2026</span> — "Clean" Cellar: Follow-up visit shows "compliant" space (concealment playbook).</p>
          </div>
        </div>
      </div>

      <!-- Valuation Evidence -->
      <div class="card border-l-2 border-war-amber">
        <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-3">Valuation Evidence — The Weapon</div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <div class="text-sm text-war-text-dim mb-2">Actual Value</div>
            <div class="metric-value text-war-text">$4.4M</div>
            <div class="metric-label">Own Spreadsheet</div>
          </div>
          <div>
            <div class="text-sm text-war-text-dim mb-2">Zillow (Unreliable)</div>
            <div class="metric-value text-war-text-dim">$5.7M</div>
          </div>
        </div>
        <div class="border-t border-war-border mt-4 pt-4 grid grid-cols-2 gap-4">
          <div>
            <div class="text-sm text-war-text-dim mb-2">Demand</div>
            <div class="metric-value text-war-red">$6–8M</div>
          </div>
          <div>
            <div class="text-sm text-war-text-dim mb-2">Premium Over Actual</div>
            <div class="metric-value text-war-red">+79%</div>
          </div>
        </div>
      </div>

      <div class="mt-4 font-mono text-xxs text-war-text-muted text-right">
        Confidential — Attorney Work Product — Prepared in Anticipation of Litigation — 13 Harrison Street, New York, NY 10013 — Feb 18, 2026
      </div>
    </section>

    <!-- ===================== SLIDE 5: Section Divider ===================== -->
    <section id="s5" data-slide="5" class="py-16 border-b border-war-border/30">
      <div class="text-center">
        <h3 class="font-display text-2xl text-war-amber tracking-tight">13 Harrison Unit 1</h3>
        <p class="font-display text-xl text-war-text-dim mt-2 italic">Real Estate Listings</p>
      </div>
    </section>

    <!-- ===================== SLIDE 6: Evidence Summary Table ===================== -->
    <section id="s6" data-slide="6" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-xxs text-war-text-muted">06</span>
        <h3 class="section-title">Summary — Bleich Actions</h3>
        <span class="badge badge-contradicted ml-auto">Evidence of Systematic Fraud &amp; Obstruction</span>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <!-- EX-02 -->
        <div class="card space-y-3">
          <div class="flex items-center gap-2">
            <span class="badge badge-alleged">EX-02</span>
            <span class="text-sm font-medium text-war-text">"Sleeping Area" Labels</span>
          </div>
          <p class="text-sm text-war-text-dim">4 cellar rooms labeled "SLEEPING AREA" + 2 full baths. Marketed as co-equal living level.</p>
          <div class="bg-war-surface2 rounded-sm p-2">
            <span class="badge badge-contradicted">Critical Evidence</span>
            <p class="text-xs text-war-text-dim mt-1">Mar 2, 2018 email: Bleich uses word "bedrooms" (plural) knowing illegality. Overrode BHS advice.</p>
          </div>
          <div class="text-xxs text-war-text-muted font-mono">SOURCE: StreetEasy Archive</div>
          <div class="text-xxs text-war-amber font-mono">MDL §34 · NYC Admin Code §27-2087 · RPL §443-a</div>
        </div>

        <!-- EX-03 -->
        <div class="card space-y-3">
          <div class="flex items-center gap-2">
            <span class="badge badge-alleged">EX-03</span>
            <span class="text-sm font-medium text-war-text">Sq. Footage Inflation</span>
          </div>
          <p class="text-sm text-war-text-dim">414.5 sqft (13.9%) inflation by counting cellar as living space.</p>
          <div class="bg-war-surface2 rounded-sm p-2">
            <span class="badge badge-contradicted">High Severity</span>
            <p class="text-xs text-war-text-dim mt-1">Public record (Decl. Sched B) clearly states 2,985 sqft. Listing claimed 3,400.</p>
          </div>
          <div class="text-xxs text-war-text-muted font-mono">SOURCE: StreetEasy #1279480</div>
          <div class="text-xxs text-war-amber font-mono">MDL §34 · NYC Admin Code §27-2087 · RPL §443-a</div>
        </div>

        <!-- EX-04 -->
        <div class="card space-y-3">
          <div class="flex items-center gap-2">
            <span class="badge badge-alleged">EX-04</span>
            <span class="text-sm font-medium text-war-text">Fraudulent Floor Numbering</span>
          </div>
          <p class="text-sm text-war-text-dim">StreetEasy listing relabels "Cellar" as "1st Floor," displaying it as co-equal living space.</p>
          <div class="bg-war-surface2 rounded-sm p-2">
            <span class="badge badge-alleged">Consciousness of Guilt</span>
            <p class="text-xs text-war-text-dim mt-1">Bleich directed relabeling specifically after learning cellar was illegal.</p>
          </div>
          <div class="text-xxs text-war-text-muted font-mono">SOURCE: Decl. Sched B; Kornmeier Dep.</div>
          <div class="text-xxs text-war-amber font-mono">MDL §34 · NYC Admin Code §27-2087 · RPL §443-a</div>
        </div>

        <!-- EX-05 -->
        <div class="card space-y-3 border-war-red/40">
          <div class="flex items-center gap-2">
            <span class="badge badge-contradicted">EX-05</span>
            <span class="text-sm font-medium text-war-text">Sheetrock Concealment (Tampering)</span>
          </div>
          <p class="text-sm text-war-text-dim">Workers installed temporary walls over cellar bedroom/bath doors before DOB inspection.</p>
          <div class="bg-war-red/5 border border-war-red/20 rounded-sm p-2">
            <span class="badge badge-contradicted">Smoking Gun (Felony)</span>
            <p class="text-xs text-war-text-dim mt-1">Affirmative construction work to physically hide evidence. Captured on video.</p>
          </div>
          <div class="text-xxs text-war-text-muted font-mono">SOURCE: iCloud Album B2XJOG15qJ8HWgR</div>
          <div class="text-xxs text-war-red font-mono">NYPL §215.40 (Class E Felony)</div>
        </div>

        <!-- EX-06 -->
        <div class="card space-y-3">
          <div class="flex items-center gap-2">
            <span class="badge badge-alleged">EX-06</span>
            <span class="text-sm font-medium text-war-text">Systematic DOB Denials</span>
          </div>
          <p class="text-sm text-war-text-dim">Three documented refusals of DOB entry to Unit 1 cellar pre-2024.</p>
          <div class="bg-war-surface2 rounded-sm p-2">
            <span class="badge badge-contradicted">Pattern of Obstruction</span>
            <p class="text-xs text-war-text-dim mt-1">Not isolated. Only reason to deny access is knowledge that inspection would reveal violations.</p>
          </div>
          <div class="text-xxs text-war-text-muted font-mono">SOURCE: DOB Public File; Berry Aff.</div>
          <div class="text-xxs text-war-amber font-mono">NYPL §195.05</div>
        </div>
      </div>

      <div class="font-mono text-xxs text-war-text-muted text-right mt-4">
        Confidential — Attorney Work Product — 13 Harrison Street, New York, NY 10013 — Feb 18, 2026
      </div>
    </section>

    <!-- ===================== SLIDE 7: Certificate of Occupancy ===================== -->
    <section id="s7" data-slide="7" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">07</span>
        <h3 class="section-title">Certificate of Occupancy</h3>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <EvidenceExhibit
            src="harassment/slide-07-certificate-of-occupancy.webp"
            alt="NYC Department of Buildings Certificate of Occupancy #107294 for 13 Harrison Street — Cellar designated as Recreation Room, Tenant Storage, Meters"
            label="Certificate of Occupancy #107294"
          />
          <div class="mt-3 card">
            <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-2">Cellar Designation</div>
            <ul class="text-sm text-war-text-dim space-y-1">
              <li>Recreation room</li>
              <li>Tenant storage</li>
              <li>Meters</li>
            </ul>
            <div class="border-t border-war-border mt-3 pt-3">
              <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-2">1st Floor</div>
              <p class="text-sm text-war-text-dim">Loft dwelling</p>
            </div>
          </div>
        </div>
        <EvidenceExhibit
          src="harassment/slide-07-schedule-b.webp"
          alt="Schedule B to the Declaration of the 13 Harrison Street Condominium — Tax Lot 1351 Unit 1: 25% interest, 2985.5 sqft, 1st Floor & part of Cellar, 8 rooms/2 baths"
          label="Schedule B — Condo Declaration"
          caption="Tax Lot 1351 (Unit 1): 25% common interest, 2,985.5 sqft, 8 rooms / 2 bathrooms. Cellar access as on floor plan."
        />
      </div>
    </section>

    <!-- ===================== SLIDE 8: Comparison Table ===================== -->
    <section id="s8" data-slide="8" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">08</span>
        <h3 class="section-title">Comparison Table — Listing vs. DOB C of O</h3>
      </div>
      <div class="bg-war-surface2 border border-war-red/20 rounded-sm p-3 mb-4">
        <span class="badge badge-contradicted">Square Footage Fraud</span>
        <span class="text-sm text-war-text-dim ml-2">414.5 sqft / 13.9% Inflation</span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr>
              <th class="table-header">Metric</th>
              <th class="table-header">As Listed</th>
              <th class="table-header">As Declared (Legal)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="table-cell font-medium text-war-text">Total Square Footage</td>
              <td class="table-cell text-war-red">3,400 sqft ("approximately")</td>
              <td class="table-cell text-war-green">2,985.5 sqft</td>
            </tr>
            <tr>
              <td class="table-cell font-medium text-war-text">Inflation</td>
              <td class="table-cell text-war-red">414.5 sqft / 13.9% over Declaration</td>
              <td class="table-cell text-war-text-dim">Declaration Schedule B, Tax Lot 1351</td>
            </tr>
            <tr>
              <td class="table-cell font-medium text-war-text">Bedroom Count</td>
              <td class="table-cell text-war-red">3–4 bedrooms (varied by listing)</td>
              <td class="table-cell text-war-green">1 bedroom (first floor only)</td>
            </tr>
            <tr>
              <td class="table-cell font-medium text-war-text">Bathroom Count</td>
              <td class="table-cell text-war-red">4 bathrooms</td>
              <td class="table-cell text-war-green">2 bathrooms (Declaration Schedule B)</td>
            </tr>
            <tr>
              <td class="table-cell font-medium text-war-text">Cellar Designation</td>
              <td class="table-cell text-war-red">"Lower Level" / "1st Floor"</td>
              <td class="table-cell text-war-green">"Cellar" — Rec Room, Tenant Storage, Meters</td>
            </tr>
            <tr>
              <td class="table-cell font-medium text-war-text">Floor Numbering</td>
              <td class="table-cell text-war-red">Cellar relabeled as "1st Floor"</td>
              <td class="table-cell text-war-green">C of O: Cellar = Cellar; 1st Floor = 1st Floor</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-3 font-mono text-xxs text-war-text-muted">
        <a href="https://www.compass.com/homedetails/13-Harrison-St-Unit-1-Manhattan-NY-10013/82551008785356097_lid/#overview" class="hover:text-war-amber transition-colors" target="_blank" rel="noopener">compass.com — 13 Harrison St Unit 1</a>
      </div>
    </section>

    <!-- ===================== SLIDE 9: Compass Listing (Floor Plan) ===================== -->
    <section id="s9" data-slide="9" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">09</span>
        <h3 class="section-title">Compass Listing — Floor Plan</h3>
      </div>
      <EvidenceExhibit
        src="harassment/slide-09-compass-floorplan.webp"
        alt="Compass alternate floor plan showing relocated staircase with cellar bedrooms, home office, and bathrooms"
        label="Compass Floor Plan — Alternate Layout"
        caption="Cellar: Bedroom 1, Bedroom 2, Home Office"
      />
      <div class="mt-3 font-mono text-xxs text-war-text-muted">
        <a href="https://www.compass.com/homedetails/13-Harrison-St-Unit-1-Manhattan-NY-10013/82551008785356097_lid/#overview" class="hover:text-war-amber transition-colors" target="_blank" rel="noopener">compass.com — 13 Harrison St Unit 1</a>
      </div>
