---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProceedingsBrowser from '../../components/ProceedingsBrowser';
import proceedings from '../../data/proceedings.json';
import claims from '../../data/claims.json';
import evidence from '../../data/evidence.json';
import events from '../../data/events.json';
---

<BaseLayout title="Proceedings" activeNav="proceedings">
  <div class="max-w-content mx-auto px-8 lg:px-12 py-10">
    <ProceedingsBrowser client:load {proceedings} {claims} {evidence} {events} />
  </div>
</BaseLayout>
