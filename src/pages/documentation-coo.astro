---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvidenceExhibit from '../components/EvidenceExhibit.astro';
import SlideProgress from '../components/SlideProgress';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Documentation — Certificate of Occupancy" activeNav="documentation-coo">
  <SlideProgress client:load />

  <div class="p-6 max-w-5xl mx-auto">

    <!-- Confidential Banner -->
    <div class="font-mono text-xxs text-war-red/60 uppercase tracking-[0.3em] text-center py-2 mb-6 border-b border-war-red/10">
      Privileged &amp; Confidential &mdash; Attorney Work Product
    </div>

    <!-- Section Jump Nav (populated by SlideProgress) -->
    <nav id="section-nav" class="sticky top-1 z-10 bg-war-bg/90 backdrop-blur border border-war-border rounded-sm py-2 px-4 mb-8 flex gap-4 overflow-x-auto">
    </nav>

    <!-- ===================== SLIDE 1: Title / Hero ===================== -->
    <section id="s1" data-slide="1" class="py-10 border-b border-war-border/30">
      <div class="text-center mb-8">
        <h1 class="font-display text-3xl text-war-text tracking-tight">13 Harrison Street, Tribeca</h1>
        <p class="font-mono text-sm text-war-text-muted mt-2">New York, NY 10013</p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <EvidenceExhibit
          src="documentation-coo/slide-01-elevation-street.webp"
          alt="Harrison Street elevation — architectural drawing of building in streetscape context"
          label="Exhibit — Street Elevation"
        />
        <EvidenceExhibit
          src="documentation-coo/slide-01-elevation-front.webp"
          alt="Front elevation — detailed architectural drawing of 13 Harrison Street facade"
          label="Exhibit — Front Elevation"
        />
      </div>
    </section>

    <!-- ===================== SLIDE 2: Overview / Table of Contents ===================== -->
    <section id="s2" data-slide="2" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">02</span>
        <h3 class="section-title">13 Harrison — Enormous Damage Report</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div class="card p-3">
          <p class="font-mono text-xs text-war-amber mb-1">I</p>
          <p class="text-sm text-war-text">Physical Layout &amp; Building Schematic</p>
        </div>
        <div class="card p-3">
          <p class="font-mono text-xs text-war-amber mb-1">II</p>
          <p class="text-sm text-war-text">Chronology of the Dispute</p>
        </div>
        <div class="card p-3">
          <p class="font-mono text-xs text-war-amber mb-1">III</p>
          <p class="text-sm text-war-text">Screenshots of Initial Bleich Correspondence</p>
        </div>
        <div class="card p-3">
          <p class="font-mono text-xs text-war-amber mb-1">IV</p>
          <p class="text-sm text-war-text">Certificate of Occupancy (CoO)</p>
        </div>
        <div class="card p-3">
          <p class="font-mono text-xs text-war-amber mb-1">V</p>
          <p class="text-sm text-war-text">Deceptive Sales Advertising</p>
        </div>
        <div class="card p-3">
          <p class="font-mono text-xs text-war-amber mb-1">VI</p>
          <p class="text-sm text-war-text">HVAC Violations (The AC Issue)</p>
        </div>
        <div class="card p-3">
          <p class="font-mono text-xs text-war-amber mb-1">VII</p>
          <p class="text-sm text-war-text">Physical Non-Compliance — Photo Evidence of Improper AC</p>
        </div>
        <div class="card p-3">
          <p class="font-mono text-xs text-war-amber mb-1">VIII</p>
          <p class="text-sm text-war-text">Impact of Bleich's "Intent to Sell"</p>
        </div>
        <div class="card p-3 md:col-span-2">
          <p class="font-mono text-xs text-war-amber mb-1">IX</p>
          <p class="text-sm text-war-text">Expert Testimony &amp; Engineering &amp; Architectural Findings</p>
        </div>
      </div>
    </section>

    <!-- ===================== SLIDE 3: Unit 1 Floorplan ===================== -->
    <section id="s3" data-slide="3" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">03</span>
        <h3 class="section-title">Unit 1 Floorplan</h3>
      </div>
      <div class="bg-war-surface2 border-l-2 border-war-red p-4 rounded-sm mb-6">
        <p class="text-sm text-war-text font-medium">4 bedrooms with boiler and no sprinkler</p>
      </div>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <EvidenceExhibit
          src="documentation-coo/slide-03-floorplan-unit1-a.webp"
          alt="Unit 1 floorplan — layout showing 4 bedrooms"
          label="Unit 1 — Plan A"
        />
        <EvidenceExhibit
          src="documentation-coo/slide-03-floorplan-unit1-b.webp"
          alt="Unit 1 floorplan — additional layout view"
          label="Unit 1 — Plan B"
        />
      </div>
      <EvidenceExhibit
        src="documentation-coo/slide-03-floorplan-unit1-c.webp"
        alt="Unit 1 floorplan — third view"
        label="Unit 1 — Plan C"
      />
    </section>

    <!-- ===================== SLIDE 4: Compass Floor Plan ===================== -->
    <section id="s4" data-slide="4" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">04</span>
        <h3 class="section-title">Compass Floor Plan</h3>
      </div>
      <p class="text-sm text-war-text-dim mb-4">As advertised on Real Estate Brokerage site</p>
      <EvidenceExhibit
        src="documentation-coo/slide-04-compass-floorplan.webp"
        alt="Compass listing floor plan for 13 Harrison St Unit 1"
        label="Compass — Floor Plan"
      />
    </section>

    <!-- ===================== SLIDE 5: Compass Floor Plan 2 ===================== -->
    <section id="s5" data-slide="5" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">05</span>
        <h3 class="section-title">Compass Floor Plan — Upper Level</h3>
      </div>
      <p class="text-sm text-war-text-dim mb-4">As advertised on Real Estate Brokerage site</p>
      <EvidenceExhibit
        src="documentation-coo/slide-05-compass-floorplan-2.webp"
        alt="Compass listing floor plan — upper level"
        label="Compass — Upper Floor Plan"
      />
    </section>

    <!-- ===================== SLIDE 6: Timeline ===================== -->
    <section id="s6" data-slide="6" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-xxs text-war-text-muted">06</span>
        <h3 class="section-title">13 Harrison Timeline</h3>
      </div>
      <p class="text-xs text-war-text-dim mb-4">Complete Forensic Chronology &amp; Evidence Map</p>

      <!-- Metrics row -->
      <div class="grid grid-cols-5 gap-3 mb-8">
        <div class="card p-3 text-center">
          <div class="metric-value">8</div>
          <div class="metric-label">Counts</div>
        </div>
        <div class="card p-3 text-center">
          <div class="metric-value">5</div>
          <div class="metric-label">Felonies</div>
        </div>
        <div class="card p-3 text-center">
          <div class="metric-value">$6–8M</div>
          <div class="metric-label">Demand</div>
        </div>
        <div class="card p-3 text-center">
          <div class="metric-value">79%</div>
          <div class="metric-label">Premium</div>
        </div>
        <div class="card p-3 text-center">
          <div class="metric-value">19yr</div>
          <div class="metric-label">Exposure</div>
        </div>
      </div>

      <!-- Timeline Phases -->
      <div class="space-y-6">
        <!-- Phase I -->
        <div class="border-l-2 border-war-amber pl-4">
          <h3 class="font-mono text-xs text-war-amber font-bold mb-2">I — The Illegal Foundation (1995–2018)</h3>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="font-mono text-xxs text-war-text-muted">1995</span> — C of O Issued: Cellar designated for storage/meters only. Never amended.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">1995</span> — Condo Decl: Unit 1 = 25% interest, 2 baths. Roof = Unit 2 exclusive.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">~2007</span> — Illegal Conversion: Bleich builds 3 bedrooms + 2 baths in cellar (no egress).</p>
            <p><span class="font-mono text-xxs text-war-text-muted">2017</span> — Broker Warning: BHS agent tells Bleich "not legal bedrooms." Bleich "annoyed."</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Mar 2, 2018</span> — "Trigger Email": Bleich writes "bedrooms" knowing illegality.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">2018–19</span> — Listing Fraud: Compass forced to correct 4BR to 1BR. StreetEasy relabels cellar "1st Floor."</p>
          </div>
        </div>

        <!-- Phase II -->
        <div class="border-l-2 border-war-amber pl-4">
          <h3 class="font-mono text-xs text-war-amber font-bold mb-2">II — Marketing Fraud & Knowledge (2017–2019)</h3>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="font-mono text-xxs text-war-text-muted">Pre-2024</span> — Access Denied: DOB inspectors blocked 3 times.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Sept 15, 2022</span> — HVAC Exposed: Technicians confirm NEITHER AC unit works. Perjury exposed.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Oct 2022</span> — Leaks Begin: Water damage starts in Unit 2 kitchen/living room.</p>
          </div>
        </div>

        <!-- Phase III -->
        <div class="border-l-2 border-war-amber pl-4">
          <h3 class="font-mono text-xs text-war-amber font-bold mb-2">III — Obstruction & Governance (2020–2023)</h3>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="font-mono text-xxs text-war-text-muted">Dec 2023</span> — Injunction: Granted based on perjury. Halts roof work.</p>
          </div>
        </div>

        <!-- Phase IV -->
        <div class="border-l-2 border-war-amber pl-4">
          <h3 class="font-mono text-xs text-war-amber font-bold mb-2">IV — The Perjury–Injunction Nexus (Jun '24–Jan '25)</h3>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="font-mono text-xxs text-war-text-muted">Jun 2024</span> — Admission: Counsel admits cellar used for sleeping in court.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Jun 21, 2024</span> — DOB Complaint: New illegal conversion filing (#1712420).</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Jan 17, 2025</span> — Temp Roof: Emergency install ($55k).</p>
          </div>
        </div>

        <!-- Phase V -->
        <div class="border-l-2 border-war-red pl-4">
          <h3 class="font-mono text-xs text-war-red font-bold mb-2">V — The Extortion (May–Sept 2025)</h3>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="font-mono text-xxs text-war-text-muted">May 24, 2025</span> — The Demand: Emails demand $6–8M. Own spreadsheet shows $4.4M value.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Aug 27, 2025</span> — Duress: Victim emails: "House leaking… let's take all demands off table."</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Sept 26, 2025</span> — The Ransom: Term Sheet §5(a): Pay or injunction continues.</p>
          </div>
        </div>

        <!-- Phase VI -->
        <div class="border-l-2 border-war-red pl-4">
          <h3 class="font-mono text-xs text-war-red font-bold mb-2">VI — The Unraveling (Oct–Dec 2025)</h3>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="font-mono text-xxs text-war-text-muted">Oct 23, 2025</span> — Gutted: Unit 2 kitchen demolished due to mold/leaks.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Nov 6, 2025</span> — Concealment: Sheetrock barriers erected over cellar doors before DOB visit (Video).</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Dec 12, 2025</span> — Perjury: Swears HVAC removal = "irreparable harm" (ACs broken).</p>
          </div>
        </div>

        <!-- Phase VII -->
        <div class="border-l-2 border-war-red pl-4">
          <h3 class="font-mono text-xs text-war-red font-bold mb-2">VII — Continuing Obstruction (Jan 2026–Present)</h3>
          <div class="space-y-2 text-sm text-war-text-dim">
            <p><span class="font-mono text-xxs text-war-text-muted">Jan 15, 2026</span> — Access Denied: DOB inspector blocked again.</p>
            <p><span class="font-mono text-xxs text-war-text-muted">Jan 28, 2026</span> — "Clean" Cellar: Follow-up visit shows "compliant" space (concealment playbook).</p>
          </div>
        </div>
      </div>

      <!-- Valuation Evidence -->
      <div class="mt-8 card p-4">
        <h3 class="font-mono text-xs text-war-amber font-bold mb-3 uppercase tracking-wider">Valuation Evidence — "The Weapon"</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center">
            <div class="metric-value text-lg">$4.4M</div>
            <div class="metric-label">Actual Value</div>
          </div>
          <div class="text-center">
            <div class="metric-value text-lg">$5.7M</div>
            <div class="metric-label">Zillow (Unreliable)</div>
          </div>
          <div class="text-center">
            <div class="metric-value text-lg text-war-red">$6–8M</div>
            <div class="metric-label">Demand</div>
          </div>
          <div class="text-center">
            <div class="metric-value text-lg text-war-red">+79%</div>
            <div class="metric-label">Premium</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== SLIDE 7: Section Divider — Listings ===================== -->
    <section id="s7" data-slide="7" class="py-10 border-b border-war-border/30">
      <div class="text-center py-8">
        <span class="font-mono text-xxs text-war-text-muted">07</span>
        <h3 class="font-display text-2xl text-war-text mt-2">13 Harrison Unit 1 Real Estate Listings</h3>
      </div>
    </section>

    <!-- ===================== SLIDE 8: Evidence Summary ===================== -->
    <section id="s8" data-slide="8" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-xxs text-war-text-muted">08</span>
        <h3 class="section-title">Summary — 13 Harrison Unit 1 — Bleich Actions</h3>
      </div>
      <p class="text-sm text-war-text-dim mb-6 font-medium">Evidence of Systematic Fraud &amp; Obstruction</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <!-- EX-02 -->
        <div class="card p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="badge-contradicted">EX-02</span>
            <span class="font-mono text-xxs text-war-red">Critical Evidence</span>
          </div>
          <h4 class="text-sm font-bold text-war-text mb-2">"Sleeping Area" Labels</h4>
          <p class="text-xs text-war-text-dim mb-3">4 cellar rooms labeled "SLEEPING AREA" + 2 full baths. Marketed as co-equal living level.</p>
          <div class="bg-war-surface2 p-2 rounded-sm">
            <p class="text-xs text-war-text-dim">Mar 2, 2018 email: Bleich uses word "bedrooms" (plural) knowing illegality. Overrode BHS advice.</p>
            <p class="font-mono text-xxs text-war-text-muted mt-1">SOURCE: StreetEasy Archive</p>
          </div>
          <p class="font-mono text-xxs text-war-amber mt-2">MDL §34</p>
        </div>

        <!-- EX-03 -->
        <div class="card p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="badge-contradicted">EX-03</span>
            <span class="font-mono text-xxs text-war-red">High Severity</span>
          </div>
          <h4 class="text-sm font-bold text-war-text mb-2">Sq. Footage Inflation</h4>
          <p class="text-xs text-war-text-dim mb-3">414.5 sqft (13.9%) inflation by counting cellar as living space.</p>
          <div class="bg-war-surface2 p-2 rounded-sm">
            <p class="text-xs text-war-text-dim">Public record (Decl. Sched B) clearly states 2,985 sqft. Listing claimed 3,400.</p>
            <p class="font-mono text-xxs text-war-text-muted mt-1">SOURCE: StreetEasy #1279480</p>
          </div>
          <p class="font-mono text-xxs text-war-amber mt-2">NYC Admin Code §27-2087</p>
        </div>

        <!-- EX-04 -->
        <div class="card p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="badge-alleged">EX-04</span>
            <span class="font-mono text-xxs text-war-amber">Consciousness of Guilt</span>
          </div>
          <h4 class="text-sm font-bold text-war-text mb-2">Fraudulent Floor Numbering</h4>
          <p class="text-xs text-war-text-dim mb-3">StreetEasy listing relabels "Cellar" as "1st Floor," displaying it as co-equal living space.</p>
          <div class="bg-war-surface2 p-2 rounded-sm">
            <p class="text-xs text-war-text-dim">Bleich directed relabeling specifically after learning cellar was illegal.</p>
            <p class="font-mono text-xxs text-war-text-muted mt-1">SOURCE: Decl. Sched B; Kornmeier Dep.</p>
          </div>
          <p class="font-mono text-xxs text-war-amber mt-2">RPL §443-a</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- EX-05 -->
        <div class="card p-4 border-l-2 border-war-red">
          <div class="flex items-center gap-2 mb-2">
            <span class="badge-contradicted">EX-05</span>
            <span class="font-mono text-xxs text-war-red font-bold">SMOKING GUN (FELONY)</span>
          </div>
          <h4 class="text-sm font-bold text-war-text mb-2">Sheetrock Concealment (Tampering)</h4>
          <p class="text-xs text-war-text-dim mb-3">Workers installed temporary walls over cellar bedroom/bath doors before DOB inspection.</p>
          <div class="bg-war-surface2 p-2 rounded-sm">
            <p class="text-xs text-war-text-dim">Affirmative construction work to physically hide evidence. Captured on video.</p>
            <p class="font-mono text-xxs text-war-text-muted mt-1">SOURCE: iCloud Album B2XJOG15qJ8HWgR</p>
          </div>
          <p class="font-mono text-xxs text-war-red mt-2">NYPL §215.40 (Class E Felony)</p>
        </div>

        <!-- EX-06 -->
        <div class="card p-4 border-l-2 border-war-amber">
          <div class="flex items-center gap-2 mb-2">
            <span class="badge-alleged">EX-06</span>
            <span class="font-mono text-xxs text-war-amber">Pattern of Obstruction</span>
          </div>
          <h4 class="text-sm font-bold text-war-text mb-2">Systematic DOB Denials</h4>
          <p class="text-xs text-war-text-dim mb-3">Three documented refusals of DOB entry to Unit 1 cellar pre-2024.</p>
          <div class="bg-war-surface2 p-2 rounded-sm">
            <p class="text-xs text-war-text-dim">Not isolated. Only reason to deny access is knowledge that inspection would reveal violations.</p>
            <p class="font-mono text-xxs text-war-text-muted mt-1">SOURCE: DOB Public File; Berry Aff.</p>
          </div>
          <p class="font-mono text-xxs text-war-amber mt-2">NYPL §195.05</p>
        </div>
      </div>
    </section>

    <!-- ===================== SLIDE 9: Certificate of Occupancy ===================== -->
    <section id="s9" data-slide="9" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">09</span>
        <h3 class="section-title">Certificate of Occupancy</h3>
      </div>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <EvidenceExhibit
          src="documentation-coo/slide-09-coo-document.webp"
          alt="Certificate of Occupancy for 13 Harrison Street"
          label="C of O Document"
        />
        <EvidenceExhibit
          src="documentation-coo/slide-09-schedule-b.webp"
          alt="Schedule B from the Condominium Declaration"
          label="Schedule B"
        />
      </div>
      <div class="grid grid-cols-2 gap-4 mt-4">
        <div class="card p-3">
          <p class="font-mono text-xxs text-war-amber mb-1">Cellar</p>
          <p class="text-sm text-war-text">Recreation room, Tenant storage, Meters</p>
        </div>
        <div class="card p-3">
          <p class="font-mono text-xxs text-war-amber mb-1">1st Floor</p>
          <p class="text-sm text-war-text">Loft dwelling</p>
        </div>
      </div>
    </section>

    <!-- ===================== SLIDE 10: Comparison Table ===================== -->
    <section id="s10" data-slide="10" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">10</span>
        <h3 class="section-title">Real Estate Listing Fraud — Comparison Table</h3>
      </div>
      <p class="text-sm text-war-text-dim mb-2">Listing vs. DOB Certificate of Occupancy</p>
      <div class="bg-war-surface2 border-l-2 border-war-red p-4 rounded-sm mb-6">
        <p class="text-sm text-war-text font-medium">Square Footage Fraud: 414.5 sqft / 13.9% Inflation</p>
        <p class="font-mono text-xxs text-war-text-muted mt-1">https://www.compass.com/homedetails/13-Harrison-St-Unit-1-Manhattan-NY-10013/82551008785356097_lid/</p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="table-header text-left">Metric</th>
              <th class="table-header text-left">As Listed</th>
              <th class="table-header text-left">As Declared (Legal)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="table-cell font-medium">Total Square Footage</td>
              <td class="table-cell text-war-red">3,400 sqft ("approximately")</td>
              <td class="table-cell">2,985.5 sqft</td>
            </tr>
            <tr>
              <td class="table-cell font-medium">Inflation / Fraud</td>
              <td class="table-cell text-war-red">414.5 sqft / 13.9% over Declaration</td>
              <td class="table-cell">Declaration Schedule B, Tax Lot 1351</td>
            </tr>
            <tr>
              <td class="table-cell font-medium">Bedroom Count</td>
              <td class="table-cell text-war-red">4 bedrooms (Compass)</td>
              <td class="table-cell">1 bedroom (first floor only)</td>
            </tr>
            <tr>
              <td class="table-cell font-medium">Bathroom Count</td>
              <td class="table-cell text-war-red">3 bathrooms</td>
              <td class="table-cell">2 bathrooms (Declaration Schedule B)</td>
            </tr>
            <tr>
