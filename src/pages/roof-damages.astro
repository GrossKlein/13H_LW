---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvidenceExhibit from '../components/EvidenceExhibit.astro';
import SlideProgress from '../components/SlideProgress';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const imgBase = 'roof-damages';
---

<BaseLayout title="Roof Leak Damages" activeNav="roof-damages">
  <SlideProgress client:load />

  <div class="p-6 max-w-5xl mx-auto">

    <!-- Confidential Banner -->
    <div class="font-mono text-xxs text-war-red/60 uppercase tracking-[0.3em] text-center py-2 mb-6 border-b border-war-red/10">
      Privileged &amp; Confidential &mdash; Attorney Work Product
    </div>

    <!-- Section Jump Nav (populated by SlideProgress) -->
    <nav id="section-nav" class="sticky top-1 z-10 bg-war-bg/90 backdrop-blur border border-war-border rounded-sm py-2 px-4 mb-8 flex gap-4 overflow-x-auto">
    </nav>

    <!-- ===================== SLIDE 1: Title ===================== -->
    <section id="s1" data-slide="1" class="py-10 border-b border-war-border/30">
      <div class="text-center mb-8">
        <p class="font-mono text-sm text-war-text-muted mb-2">Roof Leaks and Interior Damages</p>
        <h1 class="font-display text-3xl text-war-text tracking-tight">13 Harrison Street Unit 2</h1>
        <p class="font-mono text-sm text-war-text-muted mt-2">Tribeca, New York, NY 10013</p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <EvidenceExhibit
          src="roof-damages/slide-01-street-elevation.webp"
          alt="Existing Harrison Street Elevation — architectural drawing"
          label="Street Elevation"
        />
        <EvidenceExhibit
          src="roof-damages/slide-01-roof-photo.webp"
          alt="13 Harrison Street rooftop view looking towards One World Trade Center"
          label="Roof View — 13 Harrison"
        />
      </div>
    </section>

    <!-- ===================== SLIDE 2: Roof Plans Overview ===================== -->
    <section id="s2" data-slide="2" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">02</span>
        <h3 class="section-title">Roof Plans — Overview</h3>
        <span class="font-mono text-xxs text-war-text-muted ml-auto">5th Floor Roof</span>
      </div>
      <div class="grid grid-cols-3 gap-4">
        <EvidenceExhibit
          src="roof-damages/floor-plan-5th.webp"
          alt="Existing Penthouse Plan — 5th floor showing open to below, exterior roof terrace, 524.6 sq ft"
          label="5th Floor Plan"
          caption="Harrison Street side — Courtyard side. Shows 5th floor interior, exterior roof terrace."
        />
        <EvidenceExhibit
          src="roof-damages/slide-02-roof-overview.webp"
          alt="Roof overview plan showing Harrison Street and Courtyard sides"
          label="5th Floor Roof Overview"
        />
        <EvidenceExhibit
          src="roof-damages/slide-02-upper-roof.webp"
          alt="Upper roof (bulkhead) plan showing HVAC locations"
          label="HVAC Locations — Upper Roof"
        />
      </div>
    </section>

    <!-- ===================== SLIDE 3: Unfinished Roof & Cracks ===================== -->
    <section id="s3" data-slide="3" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">03</span>
        <h3 class="section-title">Unfinished Roof &amp; Cracks</h3>
      </div>
      <div class="bg-war-red/5 border border-war-red/20 rounded-sm p-4 mb-4">
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Roof membrane cracks throughout the entire roof</li>
          <li>Massive water damage on 4th and 5th fl, destroying all systems, surfaces, millwork and appliances</li>
          <li>Lack of full roofing system</li>
          <li>Lack of insulation: 4th fl is inhabitable</li>
          <li>Damaged skylights, atrium, doors</li>
        </ul>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <EvidenceExhibit src="roof-damages/slide-03-crack-1.webp" alt="Roof membrane crack — photo 1" label="Crack Evidence 1" />
        <EvidenceExhibit src="roof-damages/slide-03-crack-2.webp" alt="Roof membrane crack — photo 2" label="Crack Evidence 2" />
        <EvidenceExhibit src="roof-damages/slide-03-crack-3.webp" alt="Roof membrane crack — photo 3" label="Crack Evidence 3" />
      </div>
    </section>

    <!-- ===================== SLIDE 4: Unfinished Roof & Cracks cont. ===================== -->
    <section id="s4" data-slide="4" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">04</span>
        <h3 class="section-title">Unfinished Roof &amp; Cracks — Detail</h3>
      </div>
      <div class="grid grid-cols-3 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-04-membrane-damage.webp" alt="Damaged roof membrane showing deterioration and holes" label="Membrane Damage" />
        <EvidenceExhibit src="roof-damages/slide-04-crack-closeup.webp" alt="Roof membrane crack close-up" label="Crack Close-up" />
        <EvidenceExhibit src="roof-damages/slide-04-photo-1.webp" alt="Roof damage photo" label="Damage Photo A" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <EvidenceExhibit src="roof-damages/slide-04-photo-2.webp" alt="Roof damage photo" label="Damage Photo B" />
        <EvidenceExhibit src="roof-damages/slide-04-photo-3.webp" alt="Roof damage photo" label="Damage Photo C" />
      </div>
    </section>

    <!-- ===================== SLIDE 5: Rotten Wood Screen ===================== -->
    <section id="s5" data-slide="5" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">05</span>
        <h3 class="section-title">Unfinished Roof &amp; Rotten Wood Screen</h3>
      </div>
      <div class="bg-war-amber/5 border border-war-amber/20 rounded-sm p-4 mb-4">
        <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-2">Emergency Safety Measure</div>
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Removed rotten, detached wood screen</li>
          <li>Installed orange safety net</li>
          <li>Prevent further damages e.g. to neighboring buildings and 13 Harrison</li>
        </ul>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <EvidenceExhibit src="roof-damages/slide-05-rotten-wood-1.webp" alt="Rotten wood screen on roof" label="Rotten Wood 1" />
        <EvidenceExhibit src="roof-damages/slide-05-rotten-wood-2.webp" alt="Rotten wood screen detail" label="Rotten Wood 2" />
        <EvidenceExhibit src="roof-damages/slide-05-safety-net.webp" alt="Safety net installed after wood screen removal" label="Safety Net Installed" />
      </div>
    </section>

    <!-- ===================== SLIDE 6: Court Expert Report ===================== -->
    <section id="s6" data-slide="6" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">06</span>
        <h3 class="section-title">Evidence Report — Court Expert (Bleich)</h3>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <EvidenceExhibit src="roof-damages/slide-06-expert-report-1.webp" alt="Court expert report representing Michael Bleich — page 1" label="Expert Report — Page 1" />
        <EvidenceExhibit src="roof-damages/slide-06-expert-report-2.webp" alt="Court expert report representing Michael Bleich — page 2" label="Expert Report — Page 2" />
      </div>
    </section>

    <!-- ===================== SLIDE 7: MEP Expert Report ===================== -->
    <section id="s7" data-slide="7" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">07</span>
        <h3 class="section-title">MEP Expert Report (HZLAE) — Defective Roof Leaking</h3>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <EvidenceExhibit src="roof-damages/slide-07-mep-report-1.webp" alt="MEP expert report by HZLAE — page 1" label="MEP Report — Page 1" />
        <EvidenceExhibit src="roof-damages/slide-07-mep-report-2.webp" alt="MEP expert report by HZLAE — page 2" label="MEP Report — Page 2" />
      </div>
    </section>

    <!-- ===================== SLIDE 8: MEP Expert Report cont. ===================== -->
    <section id="s8" data-slide="8" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">08</span>
        <h3 class="section-title">MEP Expert Report (HZLAE) — Continued</h3>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <EvidenceExhibit src="roof-damages/slide-08-mep-report-3.webp" alt="MEP expert report — page 3" label="MEP Report — Page 3" />
        <EvidenceExhibit src="roof-damages/slide-08-mep-report-4.webp" alt="MEP expert report — page 4" label="MEP Report — Page 4" />
      </div>
    </section>

    <!-- ===================== SLIDE 9: Emergency Sealing ===================== -->
    <section id="s9" data-slide="9" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">09</span>
        <h3 class="section-title">Unfinished Roof &amp; Cracks — Emergency Temporary Sealing</h3>
      </div>
      <div class="bg-war-amber/5 border border-war-amber/20 rounded-sm p-4 mb-4">
        <div class="font-mono text-xxs text-war-amber uppercase tracking-widest mb-2">Emergency Temporary Sealing</div>
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Expandable Polyurethane foam applied as emergency seal to membrane and stucco walls</li>
          <li>Silicone sealant applied on all skylights and wintergarden (all glass structures)</li>
          <li>Silicone sealant applied to the cracks on the membrane</li>
        </ul>
      </div>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-09-sealing-overview.webp" alt="Roof overview showing emergency sealing areas" label="Sealing Overview" />
        <EvidenceExhibit src="roof-damages/slide-09-foam-1.webp" alt="Polyurethane foam seal — photo 1" label="Foam Seal 1" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <EvidenceExhibit src="roof-damages/slide-09-foam-2.webp" alt="Polyurethane foam seal — photo 2" label="Foam Seal 2" />
        <EvidenceExhibit src="roof-damages/slide-09-foam-3.webp" alt="Polyurethane foam seal — photo 3" label="Foam Seal 3" />
      </div>
    </section>

    <!-- ===================== SLIDE 10: Extreme Exposure Decay ===================== -->
    <section id="s10" data-slide="10" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">10</span>
        <h3 class="section-title">Unfinished Roof &amp; Extreme Exposure Decay</h3>
      </div>
      <div class="bg-war-red/5 border border-war-red/20 rounded-sm p-4 mb-4">
        <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-2">Visible Decaying Roof Membrane</div>
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Holes on membrane</li>
          <li>Rotten wood screen</li>
          <li>Corroded steel</li>
        </ul>
      </div>
      <div class="grid grid-cols-3 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-10-decay-1.webp" alt="Decaying roof membrane — holes" label="Decay 1" />
        <EvidenceExhibit src="roof-damages/slide-10-decay-2.webp" alt="Decaying roof — rotten wood" label="Decay 2" />
        <EvidenceExhibit src="roof-damages/slide-10-decay-3.webp" alt="Corroded steel on roof" label="Decay 3" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <EvidenceExhibit src="roof-damages/slide-10-decay-4.webp" alt="Roof decay detail" label="Decay 4" />
        <EvidenceExhibit src="roof-damages/slide-10-decay-5.webp" alt="Roof decay detail" label="Decay 5" />
      </div>
    </section>

    <!-- ===================== SLIDE 11: Atrium Decay ===================== -->
    <section id="s11" data-slide="11" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">11</span>
        <h3 class="section-title">Atrium Decay — Glass Structure</h3>
      </div>
      <div class="bg-war-red/5 border border-war-red/20 rounded-sm p-4 mb-4">
        <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-2">Visible Decaying Roof Glass Systems</div>
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Air and water infiltration in window glass panes</li>
          <li>Cracks in sealants</li>
          <li>Atrium structure exposed to water — corrosion</li>
          <li>Water leaks throughout the atrium to walls and interior stairwell</li>
        </ul>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <EvidenceExhibit src="roof-damages/slide-11-atrium-1.webp" alt="Atrium glass decay — corrosion" label="Atrium 1" />
        <EvidenceExhibit src="roof-damages/slide-11-atrium-2.webp" alt="Atrium glass decay — sealant cracks" label="Atrium 2" />
        <EvidenceExhibit src="roof-damages/slide-11-atrium-3.webp" alt="Atrium glass — water infiltration" label="Atrium 3" />
      </div>
    </section>

    <!-- ===================== SLIDE 12: Atrium Decay Photos ===================== -->
    <section id="s12" data-slide="12" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">12</span>
        <h3 class="section-title">Atrium Decay — Additional Photos</h3>
      </div>
      <div class="grid grid-cols-3 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-12-atrium-4.webp" alt="Atrium decay photo" label="Atrium 4" />
        <EvidenceExhibit src="roof-damages/slide-12-atrium-5.webp" alt="Atrium decay photo" label="Atrium 5" />
        <EvidenceExhibit src="roof-damages/slide-12-atrium-6.webp" alt="Atrium decay photo" label="Atrium 6" />
      </div>
      <div class="grid grid-cols-3 gap-3">
        <EvidenceExhibit src="roof-damages/slide-12-atrium-7.webp" alt="Atrium decay photo" label="Atrium 7" />
        <EvidenceExhibit src="roof-damages/slide-12-atrium-8.webp" alt="Atrium decay photo" label="Atrium 8" />
        <EvidenceExhibit src="roof-damages/slide-12-atrium-9.webp" alt="Atrium decay photo" label="Atrium 9" />
      </div>
    </section>

    <!-- ===================== SLIDE 13: Exposed Wiring ===================== -->
    <section id="s13" data-slide="13" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">13</span>
        <h3 class="section-title">Exposed Electrical Wiring &amp; Damaged Door</h3>
      </div>
      <div class="bg-war-red/5 border border-war-red/20 rounded-sm p-4 mb-4">
        <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-2">Visible Decaying Roof Membrane</div>
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Holes on membrane</li>
          <li>Exposed wires</li>
          <li>Both doors are destroyed due to water, emergency sealed</li>
        </ul>
      </div>
      <div class="grid grid-cols-3 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-13-wiring-1.webp" alt="Exposed electrical wiring on bulkhead" label="Exposed Wiring 1" />
        <EvidenceExhibit src="roof-damages/slide-13-wiring-2.webp" alt="Damaged door due to water" label="Damaged Door" />
        <EvidenceExhibit src="roof-damages/slide-13-wiring-3.webp" alt="Exposed wiring detail" label="Exposed Wiring 2" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <EvidenceExhibit src="roof-damages/slide-13-wiring-4.webp" alt="Bulkhead damage" label="Bulkhead Damage" />
        <EvidenceExhibit src="roof-damages/slide-13-wiring-5.webp" alt="Emergency sealed door" label="Emergency Sealed" />
      </div>
    </section>

    <!-- ===================== SLIDE 14: Interior Damages Divider ===================== -->
    <section id="s14" data-slide="14" class="py-16 border-b border-war-border/30">
      <div class="text-center">
        <h3 class="font-display text-2xl text-war-amber tracking-tight">Interior Damages</h3>
        <p class="font-display text-xl text-war-text-dim mt-2 italic">Unit 2 — Floor 4th &amp; 5th</p>
      </div>
    </section>

    <!-- ===================== SLIDE 15: Floor Plan Unit 2 ===================== -->
    <section id="s15" data-slide="15" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">15</span>
        <h3 class="section-title">Floor Plan — Unit 2</h3>
      </div>
      <p class="text-sm text-war-text-dim mb-4">4th floor plan — Damaged floor due to water infiltration from 5th fl roof</p>
      <EvidenceExhibit
        src="roof-damages/floor-plan-4th.webp"
        alt="Existing Fourth Floor Plan showing Kitchen/Dining, Living Room, Pantry areas — all damaged by water infiltration"
        label="4th Floor Plan — Damage Overview"
        caption="Key areas: Pantry, Kitchen/Dining, Living Room — all affected by water from 5th floor roof"
      />
    </section>

    <!-- ===================== SLIDE 16: Living Room Water Damage ===================== -->
    <section id="s16" data-slide="16" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">16</span>
        <h3 class="section-title">4th Floor — Living Room Water Damage</h3>
      </div>
      <div class="bg-war-red/5 border border-war-red/20 rounded-sm p-4 mb-4">
        <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-2">Visible Water Damage</div>
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Water destroyed ceiling sheetrock, framing, paint</li>
          <li>Water traveled throughout the entire ceiling destroying structural beams, joists, insulation</li>
          <li>Water damaged oak floor — puddles, warping of planks</li>
          <li>Water destroyed electrical system, AV system and all light fixtures</li>
        </ul>
      </div>
      <div class="grid grid-cols-3 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-16-living-1.webp" alt="Living room ceiling water damage" label="Living Room 1" />
        <EvidenceExhibit src="roof-damages/slide-16-living-2.webp" alt="Living room water damage" label="Living Room 2" />
        <EvidenceExhibit src="roof-damages/slide-16-living-3.webp" alt="Living room water damage" label="Living Room 3" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <EvidenceExhibit src="roof-damages/slide-16-living-4.webp" alt="Living room water damage — ceiling collapse" label="Living Room 4" />
        <EvidenceExhibit src="roof-damages/slide-16-living-5.webp" alt="Living room water damage — floor warping" label="Living Room 5" />
      </div>
    </section>

    <!-- ===================== SLIDE 17: Living Room cont. ===================== -->
    <section id="s17" data-slide="17" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">17</span>
        <h3 class="section-title">4th Floor — Living Room — Additional Photos</h3>
      </div>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-17-living-6.webp" alt="Living room damage detail" label="Living Room 6" />
        <EvidenceExhibit src="roof-damages/slide-17-living-7.webp" alt="Living room damage detail" label="Living Room 7" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <EvidenceExhibit src="roof-damages/slide-17-living-8.webp" alt="Living room damage detail" label="Living Room 8" />
        <EvidenceExhibit src="roof-damages/slide-17-living-9.webp" alt="Living room damage detail" label="Living Room 9" />
      </div>
    </section>

    <!-- ===================== SLIDE 18: Pantry Damage ===================== -->
    <section id="s18" data-slide="18" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">18</span>
        <h3 class="section-title">4th Floor — Pantry Water Damage</h3>
      </div>
      <div class="bg-war-red/5 border border-war-red/20 rounded-sm p-4 mb-4">
        <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-2">Visible Water Damage</div>
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Water destroyed ceiling structure, insulation</li>
          <li>Water destroyed sheetrock, framing, paint</li>
          <li>Water created mold throughout entire kitchen pantry millwork</li>
        </ul>
      </div>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-18-pantry-1.webp" alt="Pantry ceiling water damage" label="Pantry 1" />
        <EvidenceExhibit src="roof-damages/slide-18-pantry-2.webp" alt="Pantry mold damage" label="Pantry 2" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <EvidenceExhibit src="roof-damages/slide-18-pantry-3.webp" alt="Pantry millwork damage" label="Pantry 3" />
        <EvidenceExhibit src="roof-damages/slide-18-pantry-4.webp" alt="Pantry ceiling damage" label="Pantry 4" />
      </div>
    </section>

    <!-- ===================== SLIDE 19: Kitchen/Dining ===================== -->
    <section id="s19" data-slide="19" class="py-10 border-b border-war-border/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xxs text-war-text-muted">19</span>
        <h3 class="section-title">4th Floor — Kitchen/Dining Water Damage</h3>
      </div>
      <div class="bg-war-red/5 border border-war-red/20 rounded-sm p-4 mb-4">
        <div class="font-mono text-xxs text-war-red uppercase tracking-widest mb-2">Visible Water Damage</div>
        <ul class="text-sm text-war-text-dim space-y-1">
          <li>Water destroyed ceiling structure, insulation</li>
          <li>Water destroyed sheetrock, framing, paint, wallpaper</li>
          <li>Water created mold throughout entire kitchen millwork</li>
          <li>Water destroyed all kitchen appliances</li>
          <li>Water damaged oak floor — puddles, warping of planks, discoloration</li>
          <li>Water destroyed all light fixtures</li>
        </ul>
      </div>
      <div class="grid grid-cols-3 gap-3 mb-3">
        <EvidenceExhibit src="roof-damages/slide-19-kitchen-1.webp" alt="Kitchen water damage" label="Kitchen 1" />
        <EvidenceExhibit src="roof-damages/slide-19-kitchen-2.webp" alt="Kitchen water damage" label="Kitchen 2" />
        <EvidenceExhibit src="roof-damages/slide-19-kitchen-3.webp" alt="Kitchen water damage" label="Kitchen 3" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <EvidenceExhibit src="roof-damages/slide-19-kitchen-4.webp" alt="Kitchen water damage" label="Kitchen 4" />
        <EvidenceExhibit src="roof-damages/slide-19-kitchen-5.webp" alt="Kitchen water damage" label="Kitchen 5" />
      </div>
    </section>

    <!-- ===================== SLIDE 20: Kitchen/Dining cont. ===================== -->
