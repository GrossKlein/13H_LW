---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntitiesBrowser from '../../components/EntitiesBrowser';
import entities from '../../data/entities.json';
import claims from '../../data/claims.json';
import events from '../../data/events.json';
---

<BaseLayout title="Entities" activeNav="entities">
  <div class="max-w-content mx-auto px-8 lg:px-12 py-10 space-y-6">

    <div class="border-b-2 border-war-text pb-3">
      <h1 class="font-display text-2xl font-bold text-war-text">Entities</h1>
      <p class="text-war-text-dim text-sm mt-1 font-serif italic">People, organizations, and locations involved in the case</p>
    </div>

    <EntitiesBrowser client:load entities={entities} claims={claims} events={events} />

  </div>
</BaseLayout>
