---
import BaseLayout from '../layouts/BaseLayout.astro';
import claims from '../data/claims.json';
import evidence from '../data/evidence.json';
import events from '../data/events.json';
import entities from '../data/entities.json';
import proceedings from '../data/proceedings.json';

const statusCounts = {
  alleged: claims.filter((c: any) => c.claim_status === 'alleged').length,
  supported: claims.filter((c: any) => c.claim_status === 'supported').length,
  contradicted: claims.filter((c: any) => c.claim_status === 'contradicted').length,
  judicially_addressed: claims.filter((c: any) => c.claim_status === 'judicially_addressed').length,
};

const typeCounts = {
  factual_assertion: claims.filter((c: any) => c.claim_type === 'factual_assertion').length,
  legal_position: claims.filter((c: any) => c.claim_type === 'legal_position').length,
  sworn_statement: claims.filter((c: any) => c.claim_type === 'sworn_statement').length,
  allegation: claims.filter((c: any) => c.claim_type === 'allegation').length,
  expert_opinion: claims.filter((c: any) => c.claim_type === 'expert_opinion').length,
};

const evidenceTypeCounts: Record<string, number> = {};
evidence.forEach((e: any) => {
  evidenceTypeCounts[e.type] = (evidenceTypeCounts[e.type] || 0) + 1;
});

const eventTypeCounts: Record<string, number> = {};
events.forEach((e: any) => {
  eventTypeCounts[e.event_type] = (eventTypeCounts[e.event_type] || 0) + 1;
});

const linkedClaims = claims.filter((c: any) => c.supporting_evidence_ids.length > 0 || c.contradicting_evidence_ids.length > 0).length;
const linkedEvidence = evidence.filter((e: any) => e.related_claim_ids.length > 0).length;
const linkedEvents = events.filter((e: any) => e.related_claim_ids.length > 0 || e.related_evidence_ids.length > 0).length;

const recentEvents = [...events]
  .filter((e: any) => e.date && e.date !== 'unspecified')
  .sort((a: any, b: any) => b.date.localeCompare(a.date))
  .slice(0, 8);

const maxStatus = Math.max(...Object.values(statusCounts));
const maxType = Math.max(...Object.values(typeCounts));

const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
---

<BaseLayout title="Dashboard" activeNav="dashboard">
  <div class="max-w-content mx-auto px-8 lg:px-12 py-10 space-y-10">

    <!-- Headline -->
    <div class="text-center border-b border-war-border pb-8">
      <h1 class="font-blackletter text-5xl text-war-text leading-tight">Litigation Dashboard</h1>
      <p class="font-serif text-war-text-dim text-lg mt-2 italic">13 Harrison Street, TriBeCa &mdash; Michael Bleich Matter</p>
    </div>

    <!-- Metrics row -->
    <div class="grid grid-cols-5 gap-6">
      <div class="text-center py-4 border-t-2 border-war-text">
        <div class="metric-value">{claims.length}</div>
        <div class="metric-label">Claims</div>
      </div>
      <div class="text-center py-4 border-t-2 border-war-text">
        <div class="metric-value">{evidence.length}</div>
        <div class="metric-label">Evidence</div>
      </div>
      <div class="text-center py-4 border-t-2 border-war-text">
        <div class="metric-value">{events.length}</div>
        <div class="metric-label">Events</div>
      </div>
      <div class="text-center py-4 border-t-2 border-war-text">
        <div class="metric-value">{entities.length}</div>
        <div class="metric-label">Entities</div>
      </div>
      <div class="text-center py-4 border-t-2 border-war-text">
        <div class="metric-value">{proceedings.length}</div>
        <div class="metric-label">Proceedings</div>
      </div>
    </div>

    <!-- Status + Types -->
    <div class="grid grid-cols-2 gap-10">

      <!-- Claim Status -->
      <div class="space-y-4">
        <div class="flex items-center justify-between border-b-2 border-war-text pb-2">
          <h2 class="font-display text-xl font-bold">Claim Status</h2>
          <span class="font-mono text-xxs text-war-text-muted">{linkedClaims} linked</span>
        </div>
        <div class="space-y-3">
          {Object.entries(statusCounts).map(([status, count]) => (
            <div class="flex items-center gap-3">
              <span class={`badge badge-${status}`}>{status.replace('_', ' ')}</span>
              <div class="flex-1 h-1 bg-war-surface2 overflow-hidden">
                <div
                  class:list={[
                    'h-full transition-all',
                    status === 'alleged' && 'bg-war-amber',
                    status === 'supported' && 'bg-war-green',
                    status === 'contradicted' && 'bg-war-red',
                    status === 'judicially_addressed' && 'bg-war-blue',
                  ]}
                  style={`width: ${(count / maxStatus) * 100}%`}
                />
              </div>
              <span class="font-mono text-sm text-war-text-dim w-8 text-right">{count}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Claim Types -->
      <div class="space-y-4">
        <div class="flex items-center justify-between border-b-2 border-war-text pb-2">
          <h2 class="font-display text-xl font-bold">Claim Types</h2>
          <span class="font-mono text-xxs text-war-text-muted">{claims.length} total</span>
        </div>
        <div class="space-y-3">
          {Object.entries(typeCounts).map(([type, count]) => (
            <div class="flex items-center gap-3">
              <span class={`badge badge-${type}`}>{type.replace(/_/g, ' ')}</span>
              <div class="flex-1 h-1 bg-war-surface2 overflow-hidden">
                <div class="h-full bg-war-text/20" style={`width: ${(count / maxType) * 100}%`} />
              </div>
              <span class="font-mono text-sm text-war-text-dim w-8 text-right">{count}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Evidence + Events breakdown -->
    <div class="grid grid-cols-2 gap-10">
      <div class="space-y-4">
        <h2 class="font-display text-xl font-bold border-b-2 border-war-text pb-2">Evidence Breakdown</h2>
        <div class="grid grid-cols-3 gap-3">
          {Object.entries(evidenceTypeCounts).sort((a, b) => b[1] - a[1]).map(([type, count]) => (
            <div class="border border-war-border p-3">
              <div class="font-serif text-2xl font-bold text-war-text">{count}</div>
              <div class="text-xxs font-mono text-war-text-muted uppercase">{type.replace(/_/g, ' ')}</div>
            </div>
          ))}
        </div>
        <div class="text-xxs text-war-text-muted font-mono">
          {linkedEvidence} of {evidence.length} items linked to claims
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="font-display text-xl font-bold border-b-2 border-war-text pb-2">Event Breakdown</h2>
        <div class="grid grid-cols-3 gap-3">
          {Object.entries(eventTypeCounts).sort((a, b) => b[1] - a[1]).map(([type, count]) => (
            <div class="border border-war-border p-3">
              <div class="font-serif text-2xl font-bold text-war-text">{count}</div>
              <div class="text-xxs font-mono text-war-text-muted uppercase">{type.replace(/_/g, ' ')}</div>
            </div>
          ))}
        </div>
        <div class="text-xxs text-war-text-muted font-mono">
          {linkedEvents} of {events.length} events with relationship links
        </div>
      </div>
    </div>

    <!-- Recent events -->
    <div class="space-y-4">
      <div class="flex items-center justify-between border-b-2 border-war-text pb-2">
        <h2 class="font-display text-xl font-bold">Recent Events</h2>
        <a href={`${base}/timeline/`} class="text-xxs font-mono text-war-text-dim hover:text-war-text uppercase tracking-widest">View Timeline &rarr;</a>
      </div>
      <div class="divide-y divide-war-border">
        {recentEvents.map((event: any) => (
          <div class="flex items-start gap-4 py-3">
            <span class="font-mono text-xxs text-war-text-muted whitespace-nowrap pt-0.5">{event.date}</span>
            <span class={`badge badge-${event.event_type === 'filing' ? 'factual_assertion' : event.event_type === 'ruling' ? 'judicially_addressed' : event.event_type === 'obstruction' ? 'contradicted' : 'alleged'}`}>
              {event.event_type}
            </span>
            <span class="text-sm text-war-text-dim flex-1 font-serif">{event.description.length > 120 ? event.description.slice(0, 120) + '\u2026' : event.description}</span>
            <span class="font-mono text-xxs text-war-text-muted">{event.id}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>
