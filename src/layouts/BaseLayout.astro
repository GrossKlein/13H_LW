---
import HeaderNav from '../components/HeaderNav';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = '' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;

const navItems = [
  { href: `${base}/`, label: 'Dashboard', icon: 'grid', id: 'dashboard' },
  { href: `${base}/claims/`, label: 'Claims', icon: 'file-text', id: 'claims' },
  { href: `${base}/timeline/`, label: 'Timeline', icon: 'clock', id: 'timeline' },
  { href: `${base}/entities/`, label: 'Entities', icon: 'users', id: 'entities' },
  { href: `${base}/proceedings/`, label: 'Proceedings', icon: 'briefcase', id: 'proceedings' },
  { href: `${base}/graph/`, label: 'Graph', icon: 'share-2', id: 'graph' },
  { href: `${base}/harassment/`, label: 'Harassment', icon: 'warning', id: 'harassment' },
  { href: `${base}/roof-damages/`, label: 'Roof Damages', icon: 'drop', id: 'roof-damages' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} &mdash; 13 Harrison Street</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="min-h-screen flex flex-col">

    <!-- Sticky Header -->
    <header class="sticky top-0 z-50 bg-war-bg/95 backdrop-blur-sm border-b border-war-text">
      <div class="max-w-content mx-auto px-8 lg:px-12">
        <!-- Masthead -->
        <div class="flex items-center justify-between py-3 border-b border-war-border">
          <a href={`${base}/`} class="group">
            <h1 class="font-blackletter text-3xl text-war-text leading-none tracking-wide">13 Harrison Street</h1>
          </a>
          <div class="text-right">
            <div class="font-mono text-xxs text-war-text-muted uppercase tracking-widest">Litigation War Room</div>
            <div class="font-mono text-xxs text-war-text-muted">348 claims &middot; 160 evidence &middot; 165 events</div>
          </div>
        </div>
        <!-- Navigation -->
        <div class="py-2">
          <HeaderNav items={navItems} activeNav={activeNav} />
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer rule -->
    <footer class="border-t border-war-border">
      <div class="max-w-content mx-auto px-8 lg:px-12 py-4">
        <div class="font-mono text-xxs text-war-text-muted text-center">
          13 Harrison Street, TriBeCa &mdash; Litigation Data Pipeline v1.0 &mdash; 38 proceedings
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
