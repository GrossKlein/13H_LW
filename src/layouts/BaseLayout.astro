---
interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = '' } = Astro.props;

const navItems = [
  { href: '/', label: 'Dashboard', icon: 'grid', id: 'dashboard' },
  { href: '/claims/', label: 'Claims', icon: 'file-text', id: 'claims' },
  { href: '/timeline/', label: 'Timeline', icon: 'clock', id: 'timeline' },
  { href: '/entities/', label: 'Entities', icon: 'users', id: 'entities' },
  { href: '/proceedings/', label: 'Proceedings', icon: 'briefcase', id: 'proceedings' },
  { href: '/graph/', label: 'Graph', icon: 'share-2', id: 'graph' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — 13H War Room</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-56 flex-shrink-0 bg-war-surface border-r border-war-border flex flex-col">
      <div class="px-4 py-5 border-b border-war-border">
        <div class="font-display text-lg text-war-text tracking-tight">13 Harrison St</div>
        <div class="font-mono text-xxs text-war-text-muted uppercase tracking-widest mt-0.5">Litigation War Room</div>
      </div>

      <nav class="flex-1 px-2 py-3 space-y-0.5">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={['nav-link', { active: activeNav === item.id }]}
          >
            <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              {item.icon === 'grid' && <path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z" />}
              {item.icon === 'file-text' && <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8" />}
              {item.icon === 'clock' && <><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></>}
              {item.icon === 'users' && <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2 M9 7a4 4 0 100-8 4 4 0 000 8z M23 21v-2a4 4 0 00-3-3.87 M16 3.13a4 4 0 010 7.75" />}
              {item.icon === 'briefcase' && <path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" />}
              {item.icon === 'share-2' && <><circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" /><path d="M8.59 13.51l6.83 3.98 M15.41 6.51l-6.82 3.98" /></>}
            </svg>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      <div class="px-4 py-3 border-t border-war-border">
        <div class="font-mono text-xxs text-war-text-muted">
          <div>348 claims · 160 evidence</div>
          <div>165 events · 38 proceedings</div>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
