---
import SidebarNav from '../components/SidebarNav';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = '' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;

const navItems = [
  { href: `${base}/`, label: 'Dashboard', icon: 'grid', id: 'dashboard' },
  { href: `${base}/claims/`, label: 'Claims', icon: 'file-text', id: 'claims' },
  { href: `${base}/timeline/`, label: 'Timeline', icon: 'clock', id: 'timeline' },
  { href: `${base}/entities/`, label: 'Entities', icon: 'users', id: 'entities' },
  { href: `${base}/proceedings/`, label: 'Proceedings', icon: 'briefcase', id: 'proceedings' },
  { href: `${base}/graph/`, label: 'Graph', icon: 'share-2', id: 'graph' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — 13H War Room</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-56 flex-shrink-0 bg-war-surface border-r border-war-border flex flex-col">
      <div class="px-4 py-5 border-b border-war-border">
        <div class="font-display text-lg text-war-text tracking-tight">13 Harrison St</div>
        <div class="font-mono text-xxs text-war-text-muted uppercase tracking-widest mt-0.5">Litigation War Room</div>
      </div>

      <SidebarNav items={navItems} activeNav={activeNav} />

      <div class="px-4 py-3 border-t border-war-border">
        <div class="font-mono text-xxs text-war-text-muted">
          <div>348 claims · 160 evidence</div>
          <div>165 events · 38 proceedings</div>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
